<Window xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
        xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
        xmlns:plugins="clr-namespace:Mutagen.Bethesda.WPF.Plugins;assembly=Mutagen.Bethesda.WPF"
        xmlns:viewModels="clr-namespace:DialogueImplementationTool.UI.ViewModels"
        xmlns:converters="clr-namespace:DialogueImplementationTool.UI.Converters"
        xmlns:views="clr-namespace:DialogueImplementationTool.UI.Views"
        x:Class="DialogueImplementationTool.UI.Views.MainWindow"
        mc:Ignorable="d"
        d:DataContext="{d:DesignInstance viewModels:MainWindowVM}"
        x:Name="Window"
        Title="Dialogue Implementation Tool - Quest Selection"
        Height="800" Width="800"
        MinHeight="800" MinWidth="800">

    <Window.Resources>
        <!-- Skyrim Dark Color Palette -->
        <SolidColorBrush x:Key="SkyrimDeepBlack" Color="#0D0D0F"/>
        <SolidColorBrush x:Key="SkyrimDarkGray" Color="#1A1D23"/>
        <SolidColorBrush x:Key="SkyrimMediumGray" Color="#252830"/>
        <SolidColorBrush x:Key="SkyrimSlateGray" Color="#2F3541"/>
        <SolidColorBrush x:Key="SkyrimCoolGray" Color="#3D4452"/>
        <SolidColorBrush x:Key="SkyrimLightGray" Color="#5A6071"/>
        <SolidColorBrush x:Key="SkyrimSilver" Color="#8A909F"/>
        <SolidColorBrush x:Key="SkyrimPaleBlue" Color="#9EACC4"/>
        <SolidColorBrush x:Key="SkyrimIceBlue" Color="#B8C5D6"/>
        <SolidColorBrush x:Key="SkyrimAccentBlue" Color="#6B8CAE"/>
        <SolidColorBrush x:Key="SkyrimDarkAccent" Color="#4A5F7A"/>

        <!-- Dark Background Gradient -->
        <LinearGradientBrush x:Key="DarkBackgroundBrush" StartPoint="0,0" EndPoint="0,1">
            <GradientStop Color="#0D0D0F" Offset="0"/>
            <GradientStop Color="#1A1D23" Offset="0.5"/>
            <GradientStop Color="#0D0D0F" Offset="1"/>
        </LinearGradientBrush>

        <!-- Action Button Style -->
        <Style x:Key="ActionButton" TargetType="Button">
            <Setter Property="Background" Value="{StaticResource SkyrimSlateGray}"/>
            <Setter Property="Foreground" Value="{StaticResource SkyrimIceBlue}"/>
            <Setter Property="BorderBrush" Value="{StaticResource SkyrimCoolGray}"/>
            <Setter Property="BorderThickness" Value="1"/>
            <Setter Property="FontSize" Value="13"/>
            <Setter Property="FontWeight" Value="Normal"/>
            <Setter Property="Padding" Value="14,8"/>
            <Setter Property="Margin" Value="4"/>
            <Setter Property="Cursor" Value="Hand"/>
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="Button">
                        <Border x:Name="Border" 
                                Background="{TemplateBinding Background}" 
                                BorderBrush="{TemplateBinding BorderBrush}" 
                                BorderThickness="{TemplateBinding BorderThickness}"
                                CornerRadius="2"
                                Padding="{TemplateBinding Padding}">
                            <ContentPresenter HorizontalAlignment="Center" 
                                              VerticalAlignment="Center"/>
                        </Border>
                        <ControlTemplate.Triggers>
                            <Trigger Property="IsMouseOver" Value="True">
                                <Setter TargetName="Border" Property="Background" Value="{StaticResource SkyrimCoolGray}"/>
                                <Setter TargetName="Border" Property="BorderBrush" Value="{StaticResource SkyrimLightGray}"/>
                            </Trigger>
                            <Trigger Property="IsPressed" Value="True">
                                <Setter TargetName="Border" Property="Background" Value="{StaticResource SkyrimDarkGray}"/>
                            </Trigger>
                            <Trigger Property="IsEnabled" Value="False">
                                <Setter Property="Opacity" Value="0.3"/>
                            </Trigger>
                        </ControlTemplate.Triggers>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
        </Style>

        <!-- Primary Action Button -->
        <Style x:Key="PrimaryButton" TargetType="Button" BasedOn="{StaticResource ActionButton}">
            <Setter Property="Background" Value="{StaticResource SkyrimDarkAccent}"/>
            <Setter Property="Foreground" Value="{StaticResource SkyrimIceBlue}"/>
            <Setter Property="BorderBrush" Value="{StaticResource SkyrimAccentBlue}"/>
            <Setter Property="FontSize" Value="14"/>
            <Setter Property="Padding" Value="15,10"/>
            <Setter Property="Margin" Value="6"/>
        </Style>

        <!-- Small Button -->
        <Style x:Key="SmallButton" TargetType="Button" BasedOn="{StaticResource ActionButton}">
            <Setter Property="FontSize" Value="12"/>
            <Setter Property="Padding" Value="10,5"/>
        </Style>

        <!-- TextBox Style -->
        <Style x:Key="ModernTextBox" TargetType="TextBox">
            <Setter Property="Background" Value="{StaticResource SkyrimMediumGray}"/>
            <Setter Property="Foreground" Value="{StaticResource SkyrimIceBlue}"/>
            <Setter Property="BorderBrush" Value="{StaticResource SkyrimSlateGray}"/>
            <Setter Property="BorderThickness" Value="1"/>
            <Setter Property="FontFamily" Value="Segoe UI, Arial"/>
            <Setter Property="FontSize" Value="13"/>
            <Setter Property="Padding" Value="8,6"/>
            <Setter Property="CaretBrush" Value="{StaticResource SkyrimPaleBlue}"/>
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="TextBox">
                        <Border Background="{TemplateBinding Background}"
                                BorderBrush="{TemplateBinding BorderBrush}"
                                BorderThickness="{TemplateBinding BorderThickness}"
                                CornerRadius="2">
                            <ScrollViewer x:Name="PART_ContentHost"
                                          Margin="{TemplateBinding Padding}"/>
                        </Border>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
        </Style>

        <!-- Label Style -->
        <Style x:Key="ModernLabel" TargetType="Label">
            <Setter Property="Foreground" Value="{StaticResource SkyrimPaleBlue}"/>
            <Setter Property="FontFamily" Value="Segoe UI, Arial"/>
            <Setter Property="FontSize" Value="13"/>
            <Setter Property="FontWeight" Value="SemiBold"/>
            <Setter Property="Padding" Value="5"/>
        </Style>

        <!-- Menu Style -->
        <Style TargetType="Menu">
            <Setter Property="Background" Value="{StaticResource SkyrimDarkGray}"/>
            <Setter Property="Foreground" Value="{StaticResource SkyrimIceBlue}"/>
            <Setter Property="FontFamily" Value="Segoe UI, Arial"/>
            <Setter Property="FontWeight" Value="Normal"/>
            <Setter Property="BorderBrush" Value="{StaticResource SkyrimSlateGray}"/>
            <Setter Property="BorderThickness" Value="0,0,0,1"/>
            <Setter Property="Padding" Value="8,5"/>
        </Style>

        <!-- MenuItem Style -->
        <Style TargetType="MenuItem">
            <Setter Property="Foreground" Value="{StaticResource SkyrimIceBlue}"/>
            <Setter Property="FontFamily" Value="Segoe UI, Arial"/>
            <Setter Property="FontWeight" Value="Normal"/>
        </Style>

        <!-- ListView Style -->
        <Style TargetType="ListView">
            <Setter Property="Background" Value="{StaticResource SkyrimMediumGray}"/>
            <Setter Property="Foreground" Value="{StaticResource SkyrimIceBlue}"/>
            <Setter Property="BorderBrush" Value="{StaticResource SkyrimSlateGray}"/>
            <Setter Property="BorderThickness" Value="1"/>
            <Setter Property="FontFamily" Value="Segoe UI, Arial"/>
            <Setter Property="Padding" Value="6"/>
        </Style>

        <!-- Expander Style -->
        <Style TargetType="Expander">
            <Setter Property="Background" Value="{StaticResource SkyrimDarkGray}"/>
            <Setter Property="Foreground" Value="{StaticResource SkyrimPaleBlue}"/>
            <Setter Property="BorderBrush" Value="{StaticResource SkyrimSlateGray}"/>
            <Setter Property="BorderThickness" Value="1"/>
            <Setter Property="FontFamily" Value="Segoe UI, Arial"/>
            <Setter Property="FontWeight" Value="SemiBold"/>
            <Setter Property="FontSize" Value="13"/>
        </Style>
    </Window.Resources>

    <Window.Background>
        <StaticResource ResourceKey="DarkBackgroundBrush"/>
    </Window.Background>

    <Grid Margin="12">
        <Grid.RowDefinitions>
            <RowDefinition/>
            <RowDefinition Height="Auto"/>
        </Grid.RowDefinitions>

        <!-- Main Content Panel -->
        <Border Grid.Row="0"
                Background="{StaticResource SkyrimDarkGray}"
                BorderBrush="{StaticResource SkyrimSlateGray}"
                BorderThickness="1"
                CornerRadius="2"
                Padding="0"
                Margin="0,0,0,12">

            <DockPanel>
                <!-- Top Menu Bar -->
                <Menu DockPanel.Dock="Top">
                    <MenuItem Header="⚙ Open Output Folder"
                              Click="OpenFolder_OnClick"/>
                </Menu>

                <!-- Mod Prefix Section -->
                <Border DockPanel.Dock="Top"
                        Background="{StaticResource SkyrimMediumGray}"
                        BorderBrush="{StaticResource SkyrimSlateGray}"
                        BorderThickness="0,1,0,1"
                        Padding="12,10">
                    <Grid>
                        <Grid.ColumnDefinitions>
                            <ColumnDefinition Width="Auto"/>
                            <ColumnDefinition/>
                        </Grid.ColumnDefinitions>

                        <Label Grid.Column="0"
                               Target="PrefixTextBox"
                               Content="MOD PREFIX"
                               Style="{StaticResource ModernLabel}"/>

                        <TextBox x:Name="PrefixTextBox"
                                 Grid.Column="1"
                                 Margin="10,0,0,0"
                                 Text="{Binding Prefix}"
                                 Style="{StaticResource ModernTextBox}"/>
                    </Grid>
                </Border>

                <!-- Parse Buttons Section -->
                <Border DockPanel.Dock="Top"
                        Background="{StaticResource SkyrimDeepBlack}"
                        BorderBrush="{StaticResource SkyrimSlateGray}"
                        BorderThickness="0,0,0,1"
                        Padding="12">
                    <Grid>
                        <Grid.ColumnDefinitions>
                            <ColumnDefinition/>
                            <ColumnDefinition/>
                        </Grid.ColumnDefinitions>

                        <Button Grid.Column="0"
                                Command="{Binding ParseAll}"
                                Content="Parse All"
                                Style="{StaticResource PrimaryButton}"/>
                        <Button Grid.Column="1"
                                Command="{Binding AutoParseAll}"
                                Content="Auto Parse All"
                                Style="{StaticResource PrimaryButton}"/>
                    </Grid>
                </Border>

                <!-- Quest Picker Section -->
                <Border DockPanel.Dock="Top"
                        Background="{StaticResource SkyrimMediumGray}"
                        BorderBrush="{StaticResource SkyrimSlateGray}"
                        BorderThickness="0,0,0,1"
                        Padding="12">
                    <StackPanel Orientation="Horizontal">
                        <Border Background="{StaticResource SkyrimCoolGray}"
                                BorderBrush="{StaticResource SkyrimSlateGray}"
                                BorderThickness="1"
                                CornerRadius="2"
                                Padding="8,6">
                            <plugins:FormKeyPicker
                                x:Name="QuestPicker"
                                MinWidth="500"
                                LinkCache="{Binding EnvironmentContext.LinkCache, Mode=OneWay}"
                                ScopedTypes="{Binding QuestTypes, Mode=OneWay}"/>
                        </Border>

                        <Button VerticalAlignment="Center"
                                Margin="12,0,0,0"
                                Padding="12,6"
                                Content="+ Add Quest"
                                FontSize="13"
                                Click="AddQuest_OnClick"
                                Style="{StaticResource ActionButton}"/>
                    </StackPanel>
                </Border>

                <!-- Quest List -->
                <Border DockPanel.Dock="Top"
                        Background="{StaticResource SkyrimDeepBlack}"
                        BorderBrush="{StaticResource SkyrimSlateGray}"
                        BorderThickness="1,0,1,0"
                        Margin="0"
                        Padding="6">
                    <ListView ItemsSource="{Binding QuestDialogueVMs}"
                              Background="{StaticResource SkyrimMediumGray}"
                              BorderThickness="0">
                        <ListView.ItemTemplate>
                            <DataTemplate>
                                <views:QuestDialogueView DataContext="{Binding}"/>
                            </DataTemplate>
                        </ListView.ItemTemplate>
                    </ListView>
                </Border>

            </DockPanel>
        </Border>

        <!-- Warnings Expander -->
        <Border Grid.Row="1"
                Background="{StaticResource SkyrimDarkGray}"
                BorderBrush="{StaticResource SkyrimSlateGray}"
                BorderThickness="1"
                CornerRadius="2">
            <Expander Header="⚠ Warnings"
                      BorderThickness="0">
                <Grid Background="{StaticResource SkyrimMediumGray}"
                      Margin="6">
                    <Grid.RowDefinitions>
                        <RowDefinition Height="Auto"/>
                        <RowDefinition Height="200"/>
                    </Grid.RowDefinitions>

                    <Button Grid.Row="0"
                            Content="📋 Copy"
                            Command="{Binding CopyWarnings}"
                            Margin="4"
                            Padding="10,5"
                            HorizontalAlignment="Left"
                            Style="{StaticResource SmallButton}"/>

                    <Border Grid.Row="1"
                            Background="{StaticResource SkyrimDeepBlack}"
                            BorderBrush="{StaticResource SkyrimSlateGray}"
                            BorderThickness="1"
                            CornerRadius="2"
                            Margin="4"
                            Padding="4">
                        <ListView ItemsSource="{Binding Warnings}"
                                  Background="{StaticResource SkyrimMediumGray}"
                                  Foreground="{StaticResource SkyrimIceBlue}"
                                  BorderThickness="0">
                            <ListView.ItemContainerStyle>
                                <Style TargetType="ListViewItem">
                                    <Setter Property="Foreground" Value="{StaticResource SkyrimIceBlue}"/>
                                    <Setter Property="FontFamily" Value="Consolas, Courier New"/>
                                    <Setter Property="FontSize" Value="11"/>
                                </Style>
                            </ListView.ItemContainerStyle>
                        </ListView>
                    </Border>
                </Grid>
            </Expander>
        </Border>
    </Grid>
</Window>