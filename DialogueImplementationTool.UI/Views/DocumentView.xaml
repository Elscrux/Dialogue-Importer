<UserControl x:Class="DialogueImplementationTool.UI.Views.DocumentView"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
             xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
             xmlns:viewModels="clr-namespace:DialogueImplementationTool.UI.ViewModels"
             xmlns:converters="clr-namespace:DialogueImplementationTool.UI.Converters"
             xmlns:iconPacks="http://metro.mahapps.com/winfx/xaml/iconpacks"
             mc:Ignorable="d"
             d:DataContext="{d:DesignInstance viewModels:DocumentVM}"
             d:DesignHeight="100" d:DesignWidth="750">
    <UserControl.Resources>
        <converters:DocumentStatusToVisibilityConverter x:Key="DocumentStatusToVisibilityConverter"/>
        <BooleanToVisibilityConverter x:Key="BooleanToVisibilityConverter"/>

        <!-- Skyrim Dark Color Palette -->
        <SolidColorBrush x:Key="SkyrimDarkGray" Color="#1A1D23"/>
        <SolidColorBrush x:Key="SkyrimMediumGray" Color="#252830"/>
        <SolidColorBrush x:Key="SkyrimSlateGray" Color="#2F3541"/>
        <SolidColorBrush x:Key="SkyrimCoolGray" Color="#3D4452"/>
        <SolidColorBrush x:Key="SkyrimLightGray" Color="#5A6071"/>
        <SolidColorBrush x:Key="SkyrimIceBlue" Color="#B8C5D6"/>
        <SolidColorBrush x:Key="SkyrimAccentBlue" Color="#6B8CAE"/>

        <!-- Status Button Colors -->
        <SolidColorBrush x:Key="StatusParseBlue" Color="#4A7BA7"/>
        <SolidColorBrush x:Key="StatusAutoParseBlue" Color="#5B7FA7"/>
        <SolidColorBrush x:Key="StatusRunningOrange" Color="#B8763E"/>
        <SolidColorBrush x:Key="StatusImplementedGreen" Color="#4A8B5F"/>
        <SolidColorBrush x:Key="ActionOpenPurple" Color="#7B5BA7"/>

        <!-- Document Button Style -->
        <Style x:Key="DocumentButton" TargetType="Button">
            <Setter Property="Foreground" Value="{StaticResource SkyrimIceBlue}"/>
            <Setter Property="BorderBrush" Value="{StaticResource SkyrimSlateGray}"/>
            <Setter Property="BorderThickness" Value="1"/>
            <Setter Property="FontFamily" Value="Segoe UI, Arial"/>
            <Setter Property="FontSize" Value="12"/>
            <Setter Property="FontWeight" Value="Normal"/>
            <Setter Property="Padding" Value="10,4"/>
            <Setter Property="Margin" Value="2,0"/>
            <Setter Property="Cursor" Value="Hand"/>
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="Button">
                        <Border x:Name="Border" 
                                Background="{TemplateBinding Background}" 
                                BorderBrush="{TemplateBinding BorderBrush}" 
                                BorderThickness="{TemplateBinding BorderThickness}"
                                CornerRadius="2"
                                Padding="{TemplateBinding Padding}">
                            <ContentPresenter HorizontalAlignment="Center" 
                                              VerticalAlignment="Center"/>
                        </Border>
                        <ControlTemplate.Triggers>
                            <Trigger Property="IsMouseOver" Value="True">
                                <Setter TargetName="Border" Property="Background" Value="{StaticResource SkyrimCoolGray}"/>
                                <Setter TargetName="Border" Property="BorderBrush" Value="{StaticResource SkyrimLightGray}"/>
                            </Trigger>
                            <Trigger Property="IsPressed" Value="True">
                                <Setter TargetName="Border" Property="Background" Value="{StaticResource SkyrimDarkGray}"/>
                            </Trigger>
                        </ControlTemplate.Triggers>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
        </Style>

        <!-- Icon Button Style -->
        <Style x:Key="IconButton" TargetType="Button">
            <Setter Property="Background" Value="Transparent"/>
            <Setter Property="BorderThickness" Value="0"/>
            <Setter Property="Cursor" Value="Hand"/>
            <Setter Property="Padding" Value="4"/>
            <Setter Property="Margin" Value="2,0"/>
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="Button">
                        <Border x:Name="Border" 
                                Background="{TemplateBinding Background}"
                                Padding="{TemplateBinding Padding}"
                                CornerRadius="2">
                            <ContentPresenter HorizontalAlignment="Center" 
                                              VerticalAlignment="Center"/>
                        </Border>
                        <ControlTemplate.Triggers>
                            <Trigger Property="IsMouseOver" Value="True">
                                <Setter TargetName="Border" Property="Background" Value="{StaticResource SkyrimMediumGray}"/>
                            </Trigger>
                            <Trigger Property="IsPressed" Value="True">
                                <Setter TargetName="Border" Property="Background" Value="{StaticResource SkyrimDarkGray}"/>
                            </Trigger>
                        </ControlTemplate.Triggers>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
        </Style>
    </UserControl.Resources>

    <Border Background="{StaticResource SkyrimDarkGray}" 
            BorderBrush="{StaticResource SkyrimSlateGray}" 
            BorderThickness="1" 
            CornerRadius="2"
            Padding="8,6"
            Margin="0,2">
        <Grid>
            <Grid.ColumnDefinitions>
                <ColumnDefinition Width="*"/>
                <ColumnDefinition Width="Auto"/>
            </Grid.ColumnDefinitions>

            <StackPanel
                Grid.Column="0"
                Orientation="Horizontal"
                VerticalAlignment="Center">
                <iconPacks:PackIconBoxIcons
                    Kind="RegularSelectMultiple"
                    Visibility="{Binding HasCachedSelections, Converter={StaticResource BooleanToVisibilityConverter}}"
                    Foreground="{StaticResource SkyrimAccentBlue}"
                    Width="14"
                    Height="14"
                    VerticalAlignment="Center"
                    Margin="0,0,6,0"/>

                <TextBlock 
                    Text="{Binding FilePath}"
                    Foreground="{StaticResource SkyrimIceBlue}"
                    FontFamily="Segoe UI, Arial"
                    FontSize="12"
                    VerticalAlignment="Center"
                    TextTrimming="CharacterEllipsis"/>
            </StackPanel>

            <StackPanel
                Grid.Column="1"
                HorizontalAlignment="Right"
                Orientation="Horizontal"
                VerticalAlignment="Center">
                <Button
                    Command="{Binding ManualParse}"
                    Content="Parse"
                    Style="{StaticResource DocumentButton}"
                    Background="{StaticResource StatusParseBlue}"
                    Visibility="{Binding Status,
                      Converter={StaticResource DocumentStatusToVisibilityConverter},
                      ConverterParameter={x:Static viewModels:DocumentStatus.NotLoaded}}"/>
                <StackPanel
                    Visibility="{Binding HasCachedSelections, Converter={StaticResource BooleanToVisibilityConverter}}"
                    Margin="0">
                    <Button
                        Command="{Binding AutoParse}"
                        Content="Auto Parse"
                        Style="{StaticResource DocumentButton}"
                        Background="{StaticResource StatusAutoParseBlue}"
                        Visibility="{Binding Status,
                      Converter={StaticResource DocumentStatusToVisibilityConverter},
                      ConverterParameter={x:Static viewModels:DocumentStatus.NotLoaded}}"/>
                </StackPanel>
                <Button
                    Content="Running"
                    Style="{StaticResource DocumentButton}"
                    Background="{StaticResource StatusRunningOrange}"
                    IsEnabled="False"
                    Visibility="{Binding Status,
                      Converter={StaticResource DocumentStatusToVisibilityConverter},
                      ConverterParameter={x:Static viewModels:DocumentStatus.InProgress}}"/>
                <Button
                    Content="Implemented"
                    Style="{StaticResource DocumentButton}"
                    Background="{StaticResource StatusImplementedGreen}"
                    IsEnabled="False"
                    Visibility="{Binding Status,
                      Converter={StaticResource DocumentStatusToVisibilityConverter},
                      ConverterParameter={x:Static viewModels:DocumentStatus.Implemented}}"/>

                <Button
                    Command="{Binding Open}"
                    Content="Open"
                    Style="{StaticResource DocumentButton}"
                    Background="{StaticResource ActionOpenPurple}"
                    Margin="4,0,2,0"/>
                <Button 
                    Command="{Binding Delete}"
                    Style="{StaticResource IconButton}">
                    <iconPacks:PackIconBoxIcons
                        Kind="RegularTrash"
                        Foreground="#E55"
                        Width="14"
                        Height="14"
                        VerticalAlignment="Center"/>
                </Button>
            </StackPanel>
        </Grid>
    </Border>
</UserControl>